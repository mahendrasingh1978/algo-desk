# ════════════════════════════════════════════════════════════════
# AlgoDesk — Environment Variables Template
# Copy this to .env and fill in real values before starting
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
DB_NAME=algodesk
DB_USER=algodesk
DB_PASSWORD=change_me_strong_password

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── App security ────────────────────────────────────────────────
# SECRET_KEY: used for JWT tokens — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_jwt_secret_key
# ENCRYPTION_KEY: used to encrypt broker credentials in DB — generate same way — KEEP THIS SAFE
# If you lose this key all stored broker tokens are unrecoverable
ENCRYPTION_KEY=change_me_32_byte_encryption_key

# ── Super admin account (created on first startup) ───────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change_me_admin_password
SUPER_ADMIN_NAME=Admin

# ── Telegram (optional — for trade alerts) ──────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App config ──────────────────────────────────────────────────
APP_DOMAIN=https://yourdomain.duckdns.org
APP_NAME=AlgoDesk
APP_VERSION=6.0
REGISTRATION_OPEN=false
LOG_LEVEL=INFO
